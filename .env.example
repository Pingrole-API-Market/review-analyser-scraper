# MongoDB connection string (required for persistent storage)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority

# Apify (set automatically in cloud; needed for local runs)
APIFY_TOKEN=<your_apify_api_token>

# Optional — pre-set actor input for local dev (can also use INPUT.json)
# These are read from actor input at runtime, not env vars, but useful as reference:
# BUSINESS_NAME="Joe's Pizza"
# LOCATION="Berlin, Germany"
