# Apify (set automatically in cloud; needed for local runs)
APIFY_TOKEN=<your_apify_api_token>

# Email delivery (Office365 SMTP)
PINGROLE_EMAIL=<sender@yourdomain.com>
PINGROLE_PASSWORD=<office365_app_password>

# Discord delivery (bot DM)
DISCORD_TOKEN=<discord_bot_token>
DISCORD_INFRA_CHANNEL_ID=<channel_id_in_pingrole_guild>
DISCORD_WEBHOOK_URL=<optional_webhook_for_delivery_failure_alerts>
